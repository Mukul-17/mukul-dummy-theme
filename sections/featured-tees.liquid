{%- assign coll = collections[section.settings.collection] -%}
{%- if coll == blank or coll.products_count == 0 -%}{%- assign coll = collections.all -%}{%- endif -%}
<section id="drop" class="section">
  <div class="section__head reveal">
    <div class="eyebrow"><span class="eyebrow__num">{{ section.settings.eyebrow_num }}</span><span>{{ section.settings.eyebrow_label }}</span></div>
    <h2 class="section__title">{{ section.settings.heading }} <span class="t-muted">{{ section.settings.heading_accent }}</span></h2>
    {%- if section.settings.lead != blank -%}<p class="section__lead">{{ section.settings.lead }}</p>{%- endif -%}
  </div>

  <div class="rail-wrap">
    <div class="rail" id="drop-rail" aria-label="Featured products">
      {%- if coll != blank and coll.products_count > 0 -%}
        {%- for product in coll.products limit: section.settings.limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..6) -%}<article class="pcard"><div class="pcard__media"></div><div class="pcard__info"><h3 class="pcard__name">Product</h3><div class="pcard__price"><b>₹599</b></div></div></article>{%- endfor -%}
      {%- endif -%}
    </div>
    <button class="rail-arrow" id="drop-arrow" aria-label="Scroll for more tees">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6"/></svg>
    </button>
  </div>

  <div class="rail__dots" aria-hidden="true">
    {%- if coll != blank -%}
      {%- for product in coll.products limit: section.settings.limit -%}
        <span class="rail__dot {% if forloop.first %}is-active{% endif %}"></span>
      {%- endfor -%}
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Featured tees",
  "settings": [
    { "type": "text", "id": "eyebrow_num", "label": "Eyebrow number", "default": "[ 01 ]" },
    { "type": "text", "id": "eyebrow_label", "label": "Eyebrow label", "default": "The Drop" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "FEATURED" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (muted)", "default": "tees." },
    { "type": "textarea", "id": "lead", "label": "Sub text", "default": "Eight pieces. Two weights. One philosophy — clean cuts, heavyweight cotton, zero shouting." },
    { "type": "collection", "id": "collection", "label": "Collection to show" },
    { "type": "range", "id": "limit", "label": "Max products", "min": 4, "max": 16, "step": 1, "default": 12 }
  ],
  "presets": [{ "name": "Featured tees" }]
}
{% endschema %}
