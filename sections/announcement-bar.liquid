{%- assign msgs = section.settings.messages | default: 'LAUNCH SALE, FLAT ₹450 OFF, FREE SHIPPING' | split: ',' -%}
<div class="announce" role="status" aria-label="Announcements">
  <div class="announce__track" style="animation-duration: {{ section.settings.speed | default: 26 | times: 4 }}s">
    {%- for n in (1..8) -%}
      {%- for m in msgs -%}
        {%- assign words = m | strip | split: ' ' -%}
        <span class="announce__msg">{% for w in words %}{% if w contains '₹' %}<b class="announce__hl">{{ w }}</b>{% else %}{{ w }}{% endif %}{% unless forloop.last %}&nbsp;{% endunless %}{% endfor %}</span>
        <span class="announce__sep" aria-hidden="true">✦</span>
      {%- endfor -%}
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "text", "id": "messages", "label": "Messages (comma-separated)", "default": "LAUNCH SALE, FLAT ₹450 OFF, FREE SHIPPING" },
    { "type": "range", "id": "speed", "label": "Scroll speed (seconds)", "min": 12, "max": 50, "step": 2, "unit": "s", "default": 26 }
  ],
  "presets": [{ "name": "Announcement bar" }]
}
{% endschema %}
