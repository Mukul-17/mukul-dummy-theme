{%- assign ig = section.settings.handle_url | default: 'https://www.instagram.com/modrnindia' -%}
{%- capture ig_icon -%}<svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="18" height="18" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>{%- endcapture -%}

<section id="social" class="section social">
  <div class="section__head reveal">
    <div class="eyebrow"><span class="eyebrow__num">{{ section.settings.eyebrow_num }}</span><span>{{ section.settings.eyebrow_label }}</span></div>
    <h2 class="section__title">{{ section.settings.heading }} <span class="t-muted">{{ section.settings.heading_accent }}</span></h2>
    <a href="{{ ig }}" target="_blank" rel="noreferrer" class="social__handle">{{ ig_icon }}<span>{{ section.settings.handle }}</span></a>
  </div>

  {%- assign social_defaults = "https://modrn.in/cdn/shop/files/ChatGPT_Image_Apr_10_2026_02_11_09_PM.png?v=1776075534&width=800|https://modrn.in/cdn/shop/files/WhoNeedRoads_1.png?v=1777282143&width=800|https://modrn.in/cdn/shop/files/focus.png?v=1777025982&width=800|https://modrn.in/cdn/shop/files/burn_fuel.png?v=1777025982&width=800|https://modrn.in/cdn/shop/files/ChatGPT_Image_Apr_10_2026_04_49_17_PM.png?v=1776067779&width=800|https://modrn.in/cdn/shop/files/2_e2b912cb-7af2-42fc-9510-41022a9fd1f6.png?v=1777469735&width=800" | split: "|" -%}
  <div class="social-grid" id="social-grid">
    {%- assign reel_default = 'https://cdn.shopify.com/videos/c/o/v/7caf3a8202b8481286c09cf06eb0bac8.mp4' -%}
    <div class="tile tile--video reveal-fade">
      {%- if section.settings.reel_video != blank -%}
        {{ section.settings.reel_video | video_tag: autoplay: true, loop: true, muted: true, controls: false }}
      {%- else -%}
        <video autoplay muted loop playsinline preload="metadata">
          <source src="{{ section.settings.reel_url | default: reel_default }}" type="video/mp4">
        </video>
      {%- endif -%}
      <span class="tile__badge">{{ ig_icon }}</span>
      <span class="tile__play" aria-hidden="true"><svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><path d="M8 5v14l11-7z"/></svg></span>
      <a class="tile__hit" href="{{ section.settings.reel_link | default: ig }}" target="_blank" rel="noreferrer" aria-label="Watch on Instagram"></a>
    </div>
    {%- for block in section.blocks -%}
      {%- if block.settings.image != blank -%}{%- assign tsrc = block.settings.image | image_url: width: 800 -%}{%- else -%}{%- assign tsrc = social_defaults[forloop.index0] -%}{%- endif -%}
      {%- if tsrc -%}
        <a class="tile reveal-fade" href="{{ block.settings.link | default: ig }}" target="_blank" rel="noreferrer" {{ block.shopify_attributes }}>
          <img src="{{ tsrc }}" alt="MODRN community" loading="lazy" decoding="async" width="600" height="600" />
          <span class="tile__badge">{{ ig_icon }}</span>
          <span class="tile__ov"><span>{{ ig_icon }} View on IG</span></span>
        </a>
      {%- endif -%}
    {%- endfor -%}
  </div>

  <div class="social__foot reveal-fade">
    <a href="{{ ig }}" target="_blank" rel="noreferrer" class="btn btn--ghost">{{ ig_icon }}<span>Follow {{ section.settings.handle }}</span></a>
    <p class="social__tag">{{ section.settings.tagline }}</p>
  </div>
</section>

{% schema %}
{
  "name": "Social gallery",
  "settings": [
    { "type": "text", "id": "eyebrow_num", "label": "Eyebrow number", "default": "[ 05 ]" },
    { "type": "text", "id": "eyebrow_label", "label": "Eyebrow label", "default": "#ModrnInTheWild" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "SEEN ON" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (muted)", "default": "the streets." },
    { "type": "text", "id": "handle", "label": "Instagram handle", "default": "@modrnindia" },
    { "type": "url", "id": "handle_url", "label": "Instagram URL" },
    { "type": "text", "id": "tagline", "label": "Footer tagline", "default": "Tag #ModrnInTheWild to get featured." },
    { "type": "header", "content": "Reel video (tall tile)" },
    { "type": "video", "id": "reel_video", "label": "Reel video — upload" },
    { "type": "text", "id": "reel_url", "label": "…or video URL (.mp4)" },
    { "type": "url", "id": "reel_link", "label": "Reel opens (link)" }
  ],
  "blocks": [
    {
      "type": "tile",
      "name": "Photo tile",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [{
    "name": "Social gallery",
    "blocks": [
      { "type": "tile" }, { "type": "tile" }, { "type": "tile" },
      { "type": "tile" }, { "type": "tile" }, { "type": "tile" }
    ]
  }]
}
{% endschema %}
