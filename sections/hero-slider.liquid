<section class="bn" id="bnSlider" aria-label="Featured offers">

  <section class="slide bn1 on" data-dur="7200">
    <div class="s1-letters" aria-hidden="true"><span class="l1">M</span><span class="l2">R</span><span class="l3">D</span></div>
    <div class="s1-tag">FROM ₹599</div>
    <div class="s1-in">
      <p class="s1-sale">the sale</p>
      <h1 class="s1-live">IS LIVE</h1>
      <p class="s1-sub">Flat ₹450 off every oversized tee</p>
      <div class="s1-row">
        <div class="s1-slot"><div class="s1-frame"><div class="s1-pic"><img src="https://modrn.in/cdn/shop/files/ChatGPT_Image_Apr_10_2026_02_11_09_PM.png?v=1776075534&width=500" alt="" decoding="async"><span class="s1-shine"></span></div></div></div>
        <div class="s1-slot"><div class="s1-frame"><div class="s1-pic"><img src="https://modrn.in/cdn/shop/files/ChatGPT_Image_Apr_10_2026_04_49_17_PM.png?v=1776067779&width=500" alt="" decoding="async"><span class="s1-shine"></span></div></div></div>
        <div class="s1-slot"><div class="s1-frame"><div class="s1-pic"><img src="https://modrn.in/cdn/shop/files/WhoNeedRoads_1.png?v=1777282143&width=500" alt="" decoding="async"><span class="s1-shine"></span></div></div></div>
      </div>
      <a class="s1-cta" href="{{ routes.all_products_collection_url }}">Shop the sale →</a>
    </div>
  </section>

  <section class="slide bn3" data-dur="7000">
    <div class="top" data-an="1">
      <h1>Every tee<br>tells <span class="rd">a story</span></h1>
    </div>
    <div class="frame" data-an="2">
      <div class="kb"></div>
      <div class="mini m1"><img src="https://modrn.in/cdn/shop/files/VacationIcons_blue.png?v=1780475223&width=300" alt="" decoding="async"><span>Vacation ₹649</span></div>
      <div class="mini m2"><img src="https://modrn.in/cdn/shop/files/secular_socialist_iffwht_1.png?v=1779367382&width=300" alt="" decoding="async"><span>Secular ₹599</span></div>
    </div>
    <div class="below">
      <span class="tagline" data-an="3">Airplane Mode · Oversized · 220 GSM</span>
      <div class="cta-bar late"><a class="sbtn b" href="{{ routes.all_products_collection_url }}">View this tee →</a></div>
    </div>
  </section>

  <section class="slide bn4" data-dur="6800">
    <div class="half-img">
      <div class="kb"></div>
      <span class="flag">Rider favourite</span>
    </div>
    <div class="half-txt">
      <span class="kick" data-an="1">Machine Mode collection</span>
      <h1 data-an="2">Who needs <em>roads</em></h1>
      <div class="pr" data-an="3">₹699 <s>₹1,099</s><span class="off">36% OFF</span></div>
      <div class="sz" data-an="3"><b>S</b><b>M</b><b>L</b><b>XL</b><b>XXL</b></div>
      <div class="row late">
        <a class="sbtn r" href="{{ routes.all_products_collection_url }}">Buy now</a>
        <a class="sbtn o" href="{{ routes.all_products_collection_url }}">Collection</a>
      </div>
    </div>
  </section>

  <section class="slide bn5" data-dur="6500">
    <div class="kb"></div><div class="tint"></div>
    <div class="mid">
      <h1 data-an="2">Machine<br>mode <span class="shake">on.</span></h1>
      <p class="sub" data-an="3">Built for machines · Driven by instinct</p>
    </div>
    <div class="cta-wrap late"><a class="sbtn w" href="{{ routes.all_products_collection_url }}">Enter machine mode →</a></div>
  </section>

  <section class="slide bn6" data-dur="8000">
    <div class="top">
      
      <h1 data-an="2">Bestsellers<br><em>from ₹599</em></h1>
    </div>
    <div class="strip" data-an="3">
      <div class="lane">
        <a class="pc" href="{{ routes.all_products_collection_url }}"><span class="new">Hot</span><img src="https://modrn.in/cdn/shop/files/focus.png?v=1777025982&width=400" alt="" decoding="async"><b>Focus</b><span>₹599 <s>₹1,099</s></span></a>
        <a class="pc" href="{{ routes.all_products_collection_url }}"><span class="new">New</span><img src="https://modrn.in/cdn/shop/files/2_e2b912cb-7af2-42fc-9510-41022a9fd1f6.png?v=1777469735&width=400" alt="" decoding="async"><b>Unstoppable</b><span>₹599 <s>₹1,099</s></span></a>
        <a class="pc" href="{{ routes.all_products_collection_url }}"><img src="https://modrn.in/cdn/shop/files/WhoNeedRoads_1.png?v=1777282143&width=400" alt="" decoding="async"><b>Who Needs Roads</b><span>₹699 <s>₹1,099</s></span></a>
        <a class="pc" href="{{ routes.all_products_collection_url }}"><img src="https://modrn.in/cdn/shop/files/LessWheels_1_blk.png?v=1777291909&width=400" alt="" decoding="async"><b>Less Wheels</b><span>₹699 <s>₹1,099</s></span></a>
        <a class="pc" href="{{ routes.all_products_collection_url }}"><img src="https://modrn.in/cdn/shop/files/burn_fuel.png?v=1777025982&width=400" alt="" decoding="async"><b>Built To Burn Fuel</b><span>₹699 <s>₹1,099</s></span></a>
        <a class="pc" href="{{ routes.all_products_collection_url }}"><span class="new">Hot</span><img src="https://modrn.in/cdn/shop/files/focus.png?v=1777025982&width=400" alt="" decoding="async"><b>Focus</b><span>₹599 <s>₹1,099</s></span></a>
        <a class="pc" href="{{ routes.all_products_collection_url }}"><span class="new">New</span><img src="https://modrn.in/cdn/shop/files/2_e2b912cb-7af2-42fc-9510-41022a9fd1f6.png?v=1777469735&width=400" alt="" decoding="async"><b>Unstoppable</b><span>₹599 <s>₹1,099</s></span></a>
        <a class="pc" href="{{ routes.all_products_collection_url }}"><img src="https://modrn.in/cdn/shop/files/WhoNeedRoads_1.png?v=1777282143&width=400" alt="" decoding="async"><b>Who Needs Roads</b><span>₹699 <s>₹1,099</s></span></a>
        <a class="pc" href="{{ routes.all_products_collection_url }}"><img src="https://modrn.in/cdn/shop/files/LessWheels_1_blk.png?v=1777291909&width=400" alt="" decoding="async"><b>Less Wheels</b><span>₹699 <s>₹1,099</s></span></a>
        <a class="pc" href="{{ routes.all_products_collection_url }}"><img src="https://modrn.in/cdn/shop/files/burn_fuel.png?v=1777025982&width=400" alt="" decoding="async"><b>Built To Burn Fuel</b><span>₹699 <s>₹1,099</s></span></a>
      </div>
    </div>
    <div class="cta-wrap late"><a class="sbtn w" href="{{ routes.all_products_collection_url }}">Shop all bestsellers →</a></div>
  </section>

  <div class="ctrl" id="bnSegs">
    <span class="seg"><i></i></span><span class="seg"><i></i></span><span class="seg"><i></i></span>
    <span class="seg"><i></i></span><span class="seg"><i></i></span>
  </div>
  <div class="tap l" id="bnTapL" aria-label="Previous"></div>
  <div class="tap r" id="bnTapR" aria-label="Next"></div>
  <div class="arrows">
    <button id="bnPrev" aria-label="Previous">←</button>
    <button id="bnNext" aria-label="Next">→</button>
  </div>
</section>

{% schema %}
{
  "name": "Hero slider",
  "settings": [
    { "type": "paragraph", "content": "This is the 6-slide MODRN story slider (launch sale, studio video, every-tee, who-needs-roads, machine-mode, bestsellers). Slides are designed promo posters — ask to expose any text/image as an editable setting." }
  ],
  "presets": [{ "name": "Hero slider" }]
}
{% endschema %}
