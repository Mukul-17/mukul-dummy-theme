<section id="trust" class="trust">
  <div class="trust__head reveal">
    <span class="trust__kicker">{{ section.settings.kicker }}</span>
    <h2 class="trust__title">{{ section.settings.heading }} <span class="trust__outline">{{ section.settings.heading_accent }}</span></h2>
    <p class="trust__lead">{{ section.settings.lead }}</p>
  </div>

  <div class="trust__proof">
    <div class="trow"><div class="trow__ic">₹</div><div><b>Cash on delivery</b><span>Pay only when the tee is in your hands.</span></div></div>
    <div class="trow"><div class="trow__ic">⇄</div><div><b>Easy size exchange</b><span>Wrong size? We replace it — no long forms.</span></div></div>
    <div class="trow"><div class="trow__ic">🔒</div><div><b>Safe payments</b><span>Your card &amp; UPI details are always protected.</span></div></div>
    <div class="trow"><div class="trow__ic">✉</div><div><b>Real people in support</b><span>Email us — a real person replies fast.</span></div></div>
  </div>

  <div class="risk" aria-label="Your risk reduces to zero">
    <span class="risk__lbl">Your risk</span>
    <div class="risk__track"><i></i></div>
    <span class="risk__val" id="riskval">100%</span>
  </div>

  <div class="receipt-wrap">
    <div class="receipt" aria-label="MODRN trust receipt">
      <div class="receipt__head">
        <div class="receipt__logo">MODRN<span>.</span></div>
        <p>Trust receipt · No. 000-IN</p>
      </div>
      <div class="receipt__body">
        <div class="receipt__line" style="transition-delay:.3s"><span>220–240 GSM cotton</span><span class="receipt__dots"></span><span class="receipt__ok">VERIFIED</span></div>
        <div class="receipt__line" style="transition-delay:.45s"><span>Made in India</span><span class="receipt__dots"></span><span class="receipt__ok">VERIFIED</span></div>
        <div class="receipt__line" style="transition-delay:.6s"><span>Cash on delivery</span><span class="receipt__dots"></span><span class="receipt__ok">AVAILABLE</span></div>
        <div class="receipt__line" style="transition-delay:.75s"><span>Free shipping (India)</span><span class="receipt__dots"></span><span class="receipt__ok">INCLUDED</span></div>
        <div class="receipt__line" style="transition-delay:.9s"><span>Returns &amp; exchange</span><span class="receipt__dots"></span><span class="receipt__ok">COVERED</span></div>
        <div class="receipt__line" style="transition-delay:1.05s"><span>Hidden charges</span><span class="receipt__dots"></span><span class="receipt__ok">₹0.00</span></div>
        <div class="receipt__total"><span>Your risk</span><span>₹0.00</span></div>
      </div>
      <div class="receipt__foot">
        Thank you for supporting an Indian brand
        <div class="receipt__barcode" aria-hidden="true"></div>
      </div>
      <div class="receipt__stamp">MODRN<br>★ Verified ★<br>Promise</div>
    </div>
  </div>

  <div class="pay-strip" aria-hidden="true">
    <div class="pay-track">
      <span>Pay your way —</span><span><b>UPI</b></span><span><b>Visa</b></span><span><b>Mastercard</b></span><span><b>RuPay</b></span><span><b>Net Banking</b></span><span><b>Cash on Delivery</b></span><span><b>Wallets</b></span>
      <span>Pay your way —</span><span><b>UPI</b></span><span><b>Visa</b></span><span><b>Mastercard</b></span><span><b>RuPay</b></span><span><b>Net Banking</b></span><span><b>Cash on Delivery</b></span><span><b>Wallets</b></span>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Trust",
  "settings": [
    { "type": "text", "id": "kicker", "label": "Kicker", "default": "Why trust us" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "SHOP WITHOUT" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (outline)", "default": "worry." },
    { "type": "textarea", "id": "lead", "label": "Lead", "default": "We're a new Indian brand, so we don't ask you to trust us blindly. Order today and pay only when the tee reaches your hands. Wrong size? We exchange it. Simple." }
  ],
  "presets": [{ "name": "Trust" }]
}
{% endschema %}
