{%- assign v = product.selected_or_first_available_variant -%}
{%- assign on_sale = false -%}
{%- if v.compare_at_price > v.price -%}{%- assign on_sale = true -%}{%- endif -%}

<section class="ps-page template-product__inner">
  <div class="ps__gallery" id="ps-gallery">
    {%- if product.featured_image -%}
      <img id="ps-main-img" src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" width="1200" height="1500">
    {%- endif -%}
    {%- if on_sale -%}{%- assign pct = v.compare_at_price | minus: v.price | times: 100.0 | divided_by: v.compare_at_price | round -%}{%- endif -%}
    <div class="ps__hint" id="ps-hint">Tap to zoom · tap again to exit ↗</div>
  </div>

  {%- if product.images.size > 1 -%}
    <div class="rail" style="margin-top:0.75rem;">
      {%- for image in product.images -%}
        <button type="button" class="ps-thumb" data-full="{{ image | image_url: width: 1200 }}" style="flex:0 0 64px;height:80px;padding:0;border-radius:10px;overflow:hidden;border:1px solid var(--line);">
          <img src="{{ image | image_url: width: 160 }}" alt="" width="160" height="200" style="width:100%;height:100%;object-fit:cover;display:block;">
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="ps__body">
    <h1 class="ps__name">{{ product.title }}</h1>
    {%- if product.metafields.custom.gsm != blank -%}
      <p class="ps__tagline">{{ product.metafields.custom.gsm }} GSM · Oversized</p>
    {%- endif -%}

    <div class="ps__price">
      {%- if on_sale -%}<em id="ps-disc"><span class="ps__disc-sign">−</span>{{ pct }}%</em>{%- endif -%}
      <b id="ps-price">₹{{ v.price | money_without_currency | split: '.' | first }}</b>
      {%- if on_sale -%}
        <span class="ps__mrp">MRP. <s id="ps-compare">₹{{ v.compare_at_price | money_without_currency | split: '.' | first }}</s></span>
      {%- endif -%}
    </div>

    <form id="product-form" action="{{ routes.cart_url }}/add" method="post">
      {%- for option in product.options_with_values -%}
        {%- assign oname = option.name | downcase -%}
        {%- assign is_color = false -%}
        {%- if oname contains 'color' or oname contains 'colour' -%}{%- assign is_color = true -%}{%- endif -%}
        <div class="ps__group">
          <div class="ps__label">
            <span>{{ option.name }}: <span class="ps__chosen" data-chosen="{{ option.position }}">{{ option.selected_value }}</span></span>
            {%- if oname contains 'size' -%}<button type="button" class="ps__sizechart-link" id="ps-sizechart-open">Size chart ↗</button>{%- endif -%}
          </div>
          {%- if is_color -%}
            <div class="ps__swatches" data-option-position="{{ option.position }}">
              {%- for value in option.values -%}
                {%- assign cn = value | downcase -%}
                {%- assign sw = '#cbb89a' -%}
                {%- if cn contains 'white' -%}{%- assign sw = '#f1f1ee' -%}
                {%- elsif cn contains 'black' -%}{%- assign sw = '#1a1a1a' -%}
                {%- elsif cn contains 'navy' -%}{%- assign sw = '#22304f' -%}
                {%- elsif cn contains 'blue' -%}{%- assign sw = '#2f5fae' -%}
                {%- elsif cn contains 'red' -%}{%- assign sw = '#c0392b' -%}
                {%- elsif cn contains 'green' -%}{%- assign sw = '#3a7d44' -%}
                {%- elsif cn contains 'grey' or cn contains 'gray' -%}{%- assign sw = '#8a8a8a' -%}
                {%- elsif cn contains 'beige' or cn contains 'sand' or cn contains 'cream' -%}{%- assign sw = '#e3dac0' -%}
                {%- elsif cn contains 'brown' -%}{%- assign sw = '#7a5230' -%}
                {%- elsif cn contains 'olive' -%}{%- assign sw = '#6b6a3a' -%}
                {%- endif -%}
                <button type="button" class="ps__swatch{% if option.selected_value == value %} is-active{% endif %}" data-position="{{ option.position }}" data-value="{{ value | escape }}" title="{{ value | escape }}" aria-label="{{ value | escape }}"><span class="ps__swatch-dot" style="background:{{ sw }}"></span></button>
              {%- endfor -%}
            </div>
          {%- else -%}
            <div class="ps__sizes" data-option-position="{{ option.position }}">
              {%- for value in option.values -%}
                <button type="button" class="ps__size{% if option.selected_value == value %} is-active{% endif %}" data-position="{{ option.position }}" data-value="{{ value | escape }}">{{ value }}</button>
              {%- endfor -%}
            </div>
          {%- endif -%}
        </div>
      {%- endfor -%}

      <input type="hidden" name="id" id="ps-variant-id" value="{{ v.id }}">
    </form>

    <script type="application/json" id="ps-variant-data">{{ product.variants | json }}</script>

    {%- if product.description != blank -%}
      <div class="ps__group ps__details">
        <h2 class="ps__details-title">Product details</h2>
        <div class="ps__desc rte">{{ product.description }}</div>
      </div>
    {%- endif -%}
  </div>

  <div class="sizechart" id="ps-sizechart" hidden>
    <div class="sizechart__backdrop" data-sizechart-close></div>
    <div class="sizechart__panel" role="dialog" aria-modal="true" aria-label="Size chart">
      <div class="sizechart__head">
        <h3>Size Chart</h3>
        <button type="button" class="sizechart__close" data-sizechart-close aria-label="Close">×</button>
      </div>
      <p class="sizechart__sub">IN · Regular fit (inches)</p>
      <table class="sizechart__table">
        <thead><tr><th>Brand Size</th><th>IN Size</th><th>EU Size</th></tr></thead>
        <tbody>
          <tr><td>S</td><td>32–34</td><td>80–85</td></tr>
          <tr><td>M</td><td>36–38</td><td>90–95</td></tr>
          <tr><td>L</td><td>40–42</td><td>100–105</td></tr>
          <tr><td>XL</td><td>44–46</td><td>110–115</td></tr>
          <tr><td>2XL</td><td>48–50</td><td>120–125</td></tr>
        </tbody>
      </table>
    </div>
  </div>

  <div class="ps__bar">
    <div class="ps__qty">
      <button type="button" id="ps-minus" aria-label="Decrease quantity">−</button>
      <span id="ps-qty">1</span>
      <button type="button" id="ps-plus" aria-label="Increase quantity">+</button>
    </div>
    <button type="button" class="btn btn--primary ps__add" id="ps-add"{% unless product.available %} disabled{% endunless %}>
      {% if product.available %}Add to bag{% else %}Sold out{% endif %}
    </button>
  </div>
</section>

{% schema %}
{ "name": "Product page", "settings": [] }
{% endschema %}
