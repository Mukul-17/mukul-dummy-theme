{%- assign v = product.selected_or_first_available_variant -%}
{%- assign on_sale = false -%}
{%- if v.compare_at_price > v.price -%}{%- assign on_sale = true -%}{%- endif -%}

<section class="ps-page template-product__inner">
  <div class="ps__gallery">
    {%- if product.featured_image -%}
      <img id="ps-main-img" src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" width="1200" height="1500">
    {%- endif -%}
    {%- if on_sale -%}
      {%- assign pct = v.compare_at_price | minus: v.price | times: 100.0 | divided_by: v.compare_at_price | round -%}
      <span class="ps__disc">−{{ pct }}%</span>
    {%- endif -%}
  </div>

  {%- if product.images.size > 1 -%}
    <div class="rail" style="margin-top:0.75rem;">
      {%- for image in product.images -%}
        <button type="button" class="ps-thumb" data-full="{{ image | image_url: width: 1200 }}" style="flex:0 0 64px;border-radius:10px;overflow:hidden;border:1px solid var(--line);">
          <img src="{{ image | image_url: width: 160 }}" alt="" width="160" height="200" style="width:64px;height:80px;object-fit:cover;display:block;">
        </button>
      {%- endfor -%}
    </div>
  {%- endif -%}

  <div class="ps__body">
    <h1 class="ps__name">{{ product.title }}</h1>
    {%- if product.metafields.custom.gsm != blank -%}
      <p class="ps__tagline">{{ product.metafields.custom.gsm }} GSM · Oversized</p>
    {%- endif -%}

    <div class="ps__price">
      <b id="ps-price">{{ v.price | money }}</b>
      {%- if on_sale -%}
        <s id="ps-compare">{{ v.compare_at_price | money }}</s>
        <em>−{{ pct }}%</em>
      {%- endif -%}
    </div>

    <form id="product-form" action="{{ routes.cart_url }}/add" method="post">
      <div class="ps__group">
        <div class="ps__label">Size <span class="ps__chosen" id="ps-size-chosen">{{ v.title }}</span></div>
        <div class="ps__sizes" id="ps-sizes">
          {%- for variant in product.variants -%}
            <button type="button"
                    class="ps__size{% if variant.id == v.id %} is-active{% endif %}{% unless variant.available %} is-disabled{% endunless %}"
                    data-variant-id="{{ variant.id }}"
                    data-price="{{ variant.price | money }}"
                    {% if variant.compare_at_price > variant.price %}data-compare="{{ variant.compare_at_price | money }}"{% endif %}
                    data-title="{{ variant.title | escape }}">
              {{ variant.title }}
            </button>
          {%- endfor -%}
        </div>
      </div>

      <input type="hidden" name="id" id="ps-variant-id" value="{{ v.id }}">
    </form>

    {%- if product.description != blank -%}
      <div class="ps__group ps__desc rte">{{ product.description }}</div>
    {%- endif -%}
  </div>

  <div class="ps__bar">
    <div class="ps__qty">
      <button type="button" id="ps-minus" aria-label="Decrease quantity">−</button>
      <span id="ps-qty">1</span>
      <button type="button" id="ps-plus" aria-label="Increase quantity">+</button>
    </div>
    <button type="button" class="btn btn--primary ps__add" id="ps-add"{% unless product.available %} disabled{% endunless %}>
      {% if product.available %}Add to bag{% else %}Sold out{% endif %}
    </button>
  </div>
</section>

{% schema %}
{ "name": "Product page", "settings": [] }
{% endschema %}
