<section class="section section--lines newsletter">
  <div class="orb newsletter__orb"></div>
  <div class="newsletter__inner">
    <div class="eyebrow reveal"><span class="eyebrow__num">{{ section.settings.eyebrow_num }}</span><span>{{ section.settings.eyebrow_label }}</span></div>
    <h2 class="newsletter__title reveal">{{ section.settings.heading }} <span class="t-muted">{{ section.settings.heading_accent }}</span></h2>
    <p class="newsletter__lead reveal">{{ section.settings.lead }}</p>

    {%- form 'customer', class: 'newsletter__form reveal' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <input name="contact[email]" type="email" required placeholder="you@email.com" autocomplete="email" />
      <button type="submit" aria-label="Join">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </button>
      {%- if form.posted_successfully? -%}<div class="newsletter__msg" aria-live="polite">{{ section.settings.success_msg }}</div>{%- endif -%}
    {%- endform -%}

    <div class="newsletter__trust reveal">
      {%- if section.settings.trust1 != blank -%}<span>{{ section.settings.trust1 }}</span><i></i>{%- endif -%}
      {%- if section.settings.trust2 != blank -%}<span>{{ section.settings.trust2 }}</span><i></i>{%- endif -%}
      {%- if section.settings.trust3 != blank -%}<span>{{ section.settings.trust3 }}</span>{%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Newsletter",
  "settings": [
    { "type": "text", "id": "eyebrow_num", "label": "Eyebrow number", "default": "[ 07 ]" },
    { "type": "text", "id": "eyebrow_label", "label": "Eyebrow label", "default": "Early access" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "JOIN THE" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (muted)", "default": "drop list." },
    { "type": "textarea", "id": "lead", "label": "Lead", "default": "10% off your first order. Be first when new drops go live. No spam — only fire." },
    { "type": "text", "id": "success_msg", "label": "Success message", "default": "You're on the list — check your inbox for 10% off." },
    { "type": "text", "id": "trust1", "label": "Trust badge 1", "default": "10% off first order" },
    { "type": "text", "id": "trust2", "label": "Trust badge 2", "default": "First on new drops" },
    { "type": "text", "id": "trust3", "label": "Trust badge 3", "default": "Zero spam" }
  ],
  "presets": [{ "name": "Newsletter" }]
}
{% endschema %}
