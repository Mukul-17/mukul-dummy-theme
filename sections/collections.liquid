{%- comment -%}
  Tee-tag category switcher. Tags = store collections (Admin-managed: add/edit/
  delete/reorder collections and their cover images in Admin and they appear here).
  Tapping a tee filters the product grid below and updates the heading + count.
  Products come from the store catalog; each card is tagged with its collections.
{%- endcomment -%}
{%- assign rots = "-4deg|3deg|-2deg|4deg|-3deg|2deg" | split: "|" -%}

{%- comment -%} Payment marquee placed above Collections (separate copy; the Trust section keeps its own .pay-track). {%- endcomment -%}
{%- assign cat_pay_methods = "UPI, Visa, Mastercard, RuPay, Net Banking, Cash on Delivery, Wallets" | split: ',' -%}
{%- assign pay_palette = "#e03e1f,#1aa85a,#2f6fed,#e2a400,#9b51e0,#e84393,#00b8a9" | split: ',' -%}
<div class="pay-strip pay-strip--top" aria-hidden="true">
  <span class="pay-fixed">Pay your way</span>
  <div class="pay-track">
    {%- for n in (1..2) -%}
      <span class="pay-intro">Pay your way —</span>{%- for m in cat_pay_methods -%}{%- assign pci = forloop.index0 | modulo: 7 -%}<span class="pay-pill" style="--dot:{{ pay_palette[pci] }}"><b>{{ m | strip }}</b></span>{%- endfor -%}
    {%- endfor -%}
  </div>
</div>

<section id="collections" class="section catsec">
  <div class="section__head reveal">
    <div class="eyebrow"><span class="eyebrow__num">{{ section.settings.eyebrow_num }}</span><span>{{ section.settings.eyebrow_label }}</span></div>
    <h2 class="section__title">{{ section.settings.heading }} <span class="t-muted">{{ section.settings.heading_accent }}</span></h2>
    {%- if section.settings.lead != blank -%}<p class="section__lead">{{ section.settings.lead }}</p>{%- endif -%}
  </div>

  <div class="chips" aria-label="Shop by category">
    <div class="chip-rod" aria-hidden="true"></div>
    <div class="chips-scroll" id="cat-chips">
      <button type="button" class="chip is-active" data-cat="__all" data-label="{{ section.settings.all_label | escape }}" style="--rot:-3deg">
        <span class="tee"><span class="collar"></span>{% render 'tee-icon', key: 'grid' %}</span>
        <span class="chip-lbl">{{ section.settings.all_label }}</span>
      </button>
      {%- assign icycle = "sparkle,flame,helmet,compass,coffee,bolt,layers" | split: "," -%}
      {%- for c in collections -%}
        {%- unless c.handle == 'frontpage' -%}
          {%- assign ri = forloop.index0 | modulo: 6 -%}
          {%- assign t = c.title | downcase -%}
          {%- if t contains 'machine' or t contains 'moto' or t contains 'rider' or t contains 'road' or t contains 'wheel' -%}{%- assign ikey = 'helmet' -%}
          {%- elsif t contains 'vacation' or t contains 'travel' or t contains 'trip' or t contains 'airplane' -%}{%- assign ikey = 'compass' -%}
          {%- elsif t contains 'coffee' or t contains 'caffeine' -%}{%- assign ikey = 'coffee' -%}
          {%- elsif t contains 'minimal' or t contains 'essential' or t contains 'clean' or t contains 'basic' -%}{%- assign ikey = 'sparkle' -%}
          {%- elsif t contains 'bold' or t contains 'high' or t contains 'standard' or t contains 'cricket' or t contains 'game' -%}{%- assign ikey = 'bolt' -%}
          {%- elsif t contains '220' or t contains '240' or t contains 'gsm' or t contains 'heavy' -%}{%- assign ikey = 'layers' -%}
          {%- elsif t contains 'hot' or t contains 'fire' or t contains 'cockroach' or t contains 'society' -%}{%- assign ikey = 'flame' -%}
          {%- else -%}{%- assign im = forloop.index0 | modulo: 7 -%}{%- assign ikey = icycle[im] -%}{%- endif -%}
          <button type="button" class="chip" data-cat="{{ c.handle }}" data-label="{{ c.title | escape }}" style="--rot:{{ rots[ri] }}">
            <span class="tee"><span class="collar"></span>{% render 'tee-icon', key: ikey %}</span>
            <span class="chip-lbl">{{ c.title }}</span>
          </button>
        {%- endunless -%}
      {%- endfor -%}
    </div>
  </div>

  <div class="feed-head">
    <h3 id="cat-heading">{{ section.settings.all_label }}</h3>
    <span class="count" id="cat-count"></span>
  </div>

  <div class="pgrid catgrid" id="cat-grid" aria-label="Products">
    {%- for product in collections.all.products limit: section.settings.limit -%}
      {%- capture cats -%}{% for pc in product.collections %}{{ pc.handle }} {% endfor %}{%- endcapture -%}
      {% render 'product-card', product: product, cats: cats %}
    {%- else -%}
      {%- for i in (1..4) -%}<article class="pcard"><div class="pcard__media"></div><div class="pcard__info"><h3 class="pcard__name">Product</h3><div class="pcard__price"><b>₹599</b></div></div></article>{%- endfor -%}
    {%- endfor -%}
  </div>
</section>

{% schema %}
{
  "name": "Category switcher",
  "settings": [
    { "type": "text", "id": "eyebrow_num", "label": "Eyebrow number", "default": "[ 02 ]" },
    { "type": "text", "id": "eyebrow_label", "label": "Eyebrow label", "default": "Collections" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "EVERY TEE IS" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (muted)", "default": "a mindset." },
    { "type": "textarea", "id": "lead", "label": "Sub text", "default": "Pick a mindset — the drop below filters to match." },
    { "type": "text", "id": "all_label", "label": "First tag label", "default": "All" },
    { "type": "range", "id": "limit", "label": "Max products loaded", "min": 12, "max": 50, "step": 2, "default": 36 }
  ],
  "presets": [{ "name": "Category switcher" }]
}
{% endschema %}
