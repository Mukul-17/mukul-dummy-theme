<section id="anatomy" class="section anatomy">
  <div class="section__head reveal">
    <div class="eyebrow"><span class="eyebrow__num">{{ section.settings.eyebrow_num }}</span><span>{{ section.settings.eyebrow_label }}</span></div>
    <h2 class="section__title">{{ section.settings.heading }} <span class="t-muted">{{ section.settings.heading_accent }}</span></h2>
    {%- if section.settings.lead != blank -%}<p class="section__lead">{{ section.settings.lead }}</p>{%- endif -%}
  </div>

  <div class="a-pinwrap">
   <div class="a-pin">
  <div class="anatomy__diagram reveal">
    <svg class="tee-svg" viewBox="0 0 520 560" fill="none" xmlns="http://www.w3.org/2000/svg" aria-label="Diagram of an oversized tee with construction details">
      <path class="tee-body" d="M170 90 C195 60 325 60 350 90 L470 150 L440 235 L385 210 L385 500 C385 515 135 515 135 500 L135 210 L80 235 L50 150 Z"/>
      <path class="tee-body" d="M195 88 C225 122 295 122 325 88" />
      <path class="tee-stitch" d="M203 96 C228 126 292 126 317 96"/>
      <path class="tee-stitch" d="M145 495 L375 495"/>
      <path class="tee-stitch" d="M90 222 L140 200 M430 222 L380 200"/>
      <text class="tee-emb" x="260" y="325" text-anchor="middle">MODRN</text>
      <g class="hotspot" data-i="0">
        <line class="lead" x1="260" y1="112" x2="260" y2="44"/>
        <text class="spot-num" x="260" y="34" text-anchor="middle">01</text>
        <circle class="pulse" cx="260" cy="112" r="6"/><circle class="core" cx="260" cy="112" r="6"/>
      </g>
      <g class="hotspot" data-i="1">
        <line class="lead" x1="438" y1="182" x2="500" y2="146"/>
        <text class="spot-num" x="508" y="140" text-anchor="middle">02</text>
        <circle class="pulse" cx="438" cy="182" r="6"/><circle class="core" cx="438" cy="182" r="6"/>
      </g>
      <g class="hotspot" data-i="2">
        <line class="lead" x1="260" y1="312" x2="166" y2="372"/>
        <text class="spot-num" x="150" y="380" text-anchor="end">03</text>
        <circle class="pulse" cx="260" cy="312" r="6"/><circle class="core" cx="260" cy="312" r="6"/>
      </g>
      <g class="hotspot" data-i="3">
        <line class="lead" x1="360" y1="495" x2="438" y2="540"/>
        <text class="spot-num" x="452" y="550" text-anchor="start">04</text>
        <circle class="pulse" cx="360" cy="495" r="6"/><circle class="core" cx="360" cy="495" r="6"/>
      </g>
    </svg>
  </div>

  <div class="anatomy__steps" id="anatomy-steps">
    {%- for block in section.blocks -%}
      <div class="astep reveal" data-i="{{ forloop.index0 }}" {{ block.shopify_attributes }}>
        <span class="astep__num">{{ block.settings.num }}</span>
        <h3 class="astep__title">{{ block.settings.title }}</h3>
        <p class="astep__copy">{{ block.settings.copy }}</p>
      </div>
    {%- endfor -%}
    <div class="a-progress" aria-hidden="true"><i></i></div>
  </div>
   </div>
  </div>
</section>

{% schema %}
{
  "name": "Anatomy",
  "settings": [
    { "type": "text", "id": "eyebrow_num", "label": "Eyebrow number", "default": "[ 03 ]" },
    { "type": "text", "id": "eyebrow_label", "label": "Eyebrow label", "default": "Why it feels different" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "ANATOMY OF A" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (muted)", "default": "modrn tee." },
    { "type": "textarea", "id": "lead", "label": "Sub text", "default": "Keep scrolling — every detail gets inspected." }
  ],
  "blocks": [
    {
      "type": "step",
      "name": "Detail step",
      "settings": [
        { "type": "text", "id": "num", "label": "Label", "default": "01 — Collar" },
        { "type": "text", "id": "title", "label": "Title", "default": "Ribbed neck that won't sag" },
        { "type": "textarea", "id": "copy", "label": "Copy", "default": "Double-layered ribbed collar with reinforced stitching — holds its shape on the 50th wear like the first." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [{
    "name": "Anatomy",
    "blocks": [
      { "type": "step", "settings": { "num": "01 — Collar", "title": "Ribbed neck that won't sag", "copy": "Double-layered ribbed collar with reinforced stitching — holds its shape on the 50th wear like the first." } },
      { "type": "step", "settings": { "num": "02 — Shoulder", "title": "True drop-shoulder cut", "copy": "Pattern-cut for the oversized silhouette — relaxed through the shoulder without looking sloppy." } },
      { "type": "step", "settings": { "num": "03 — Chest", "title": "Refined embroidery & print", "copy": "Precision embroidery and high-density prints that survive wash after wash without cracking." } },
      { "type": "step", "settings": { "num": "04 — Hem", "title": "Double-needle hem", "copy": "Twin-stitched hem and sleeves for structure at the edges — where cheap tees give up first." } }
    ]
  }]
}
{% endschema %}
