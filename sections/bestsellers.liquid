{%- assign coll = collections[section.settings.collection] -%}
{%- if coll == blank or coll.products_count == 0 -%}{%- assign coll = collections.all -%}{%- endif -%}
<section id="bestsellers" class="section bestsec">
  <div class="section__head reveal">
    <div class="eyebrow"><span class="eyebrow__num">{{ section.settings.eyebrow_num }}</span><span>{{ section.settings.eyebrow_label }}</span></div>
    <h2 class="section__title">{{ section.settings.heading }} <span class="t-muted">{{ section.settings.heading_accent }}</span></h2>
    {%- if section.settings.lead != blank -%}<p class="section__lead">{{ section.settings.lead }}</p>{%- endif -%}
  </div>

  <div class="rail-wrap">
    <div class="rail brail" id="best-rail" aria-label="Bestselling products">
      {%- for product in coll.products limit: section.settings.limit -%}
        {%- assign on_sale = false -%}{%- if product.compare_at_price > product.price -%}{%- assign on_sale = true -%}{%- endif -%}
        {%- assign badge = product.metafields.custom.badge | default: section.settings.default_badge -%}
        {%- assign fit = product.metafields.custom.fit | default: section.settings.default_fit -%}
        <a class="bcard" href="{{ product.url }}">
          {%- if product.featured_image -%}
            <img class="bcard__img" src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.title | escape }}" loading="lazy" decoding="async" width="800" height="1100">
          {%- endif -%}
          <div class="bcard__grad"></div>
          {%- if badge != blank -%}<span class="bcard__badge">{{ badge }}</span>{%- endif -%}
          {%- if fit != blank -%}<span class="bcard__fit">{{ fit }}</span>{%- endif -%}
          <div class="bcard__pill">
            <span class="bcard__name">{{ product.title }}</span>
            <span class="bcard__price">{{ product.price | money }}{%- if on_sale -%}<s>{{ product.compare_at_price | money }}</s>{%- endif -%}</span>
          </div>
        </a>
      {%- else -%}
        {%- for i in (1..4) -%}<div class="bcard"><div class="bcard__pill"><span class="bcard__name">Product</span><span class="bcard__price">₹599</span></div></div>{%- endfor -%}
      {%- endfor -%}
    </div>
    <button class="rail-arrow" id="best-arrow" aria-label="Scroll for more">
      <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="m9 6 6 6-6 6"/></svg>
    </button>
  </div>
</section>

{% schema %}
{
  "name": "Bestsellers",
  "settings": [
    { "type": "text", "id": "eyebrow_num", "label": "Eyebrow symbol", "default": "★" },
    { "type": "text", "id": "eyebrow_label", "label": "Eyebrow label", "default": "Bestsellers" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "MOST" },
    { "type": "text", "id": "heading_accent", "label": "Heading accent (muted)", "default": "loved." },
    { "type": "textarea", "id": "lead", "label": "Sub text", "default": "The pieces India keeps reordering — flying out fastest." },
    { "type": "collection", "id": "collection", "label": "Collection to show" },
    { "type": "range", "id": "limit", "label": "Max products", "min": 2, "max": 12, "step": 1, "default": 8 },
    { "type": "text", "id": "default_badge", "label": "Default badge (if product has none)", "default": "Bestseller" },
    { "type": "text", "id": "default_fit", "label": "Default fit label", "default": "Oversized Fit" }
  ],
  "presets": [{ "name": "Bestsellers" }]
}
{% endschema %}
