<section class="section">
  <div class="section__head reveal">
    <div class="eyebrow"><span>{{ collection.products_count }} {% if collection.products_count == 1 %}piece{% else %}pieces{% endif %}</span></div>
    <h3 class="coll-title">{{ collection.title }}</h3>
    {%- if collection.description != blank -%}
      <p class="section__lead">{{ collection.description }}</p>
    {%- endif -%}
  </div>

  {%- paginate collection.products by 24 -%}
    <div class="pgrid" id="collection-grid">
      {%- for product in collection.products -%}
        {% render 'product-card', product: product %}
      {%- else -%}
        <p class="section__lead">No products in this collection yet.</p>
      {%- endfor -%}
    </div>

    {%- if paginate.next -%}
      <div class="section__cta load-more-wrap" style="display:flex;justify-content:center;margin-top:2rem;">
        <button type="button" class="btn btn--primary load-more" data-next="{{ paginate.next.url }}">More →</button>
      </div>
    {%- endif -%}
  {%- endpaginate -%}
</section>

{% schema %}
{ "name": "Collection", "settings": [] }
{% endschema %}
