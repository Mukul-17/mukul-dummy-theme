<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, maximum-scale=5.0">
  <meta name="theme-color" content="#060606">
  <title>{% if request.page_type == 'index' %}{{ settings.seo_title | default: 'MODRN' }}{% else %}{{ page_title }} · MODRN{% endif %}</title>
  {% if page_description %}<meta name="description" content="{{ page_description | escape }}">{% endif %}

  <link rel="icon" type="image/png" href="{% if settings.favicon != blank %}{{ settings.favicon | image_url: width: 64 }}{% else %}https://modrn.in/cdn/shop/files/Screenshot_2026-03-26_at_10.02.28_PM.png?crop=center&height=64&v=1774542795&width=64{% endif %}">
  <link rel="apple-touch-icon" href="{% if settings.favicon != blank %}{{ settings.favicon | image_url: width: 180 }}{% else %}https://modrn.in/cdn/shop/files/Screenshot_2026-03-26_at_10.02.28_PM.png?crop=center&height=180&v=1774542795&width=180{% endif %}">

  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Archivo:ital,wght@0,400;0,500;0,600;0,800;0,900;1,300;1,400&family=Archivo+Black&family=IBM+Plex+Mono:wght@400;500&family=Caveat:wght@600&display=swap" rel="stylesheet">

  {{ 'styles.css' | asset_url | stylesheet_tag }}

  {{ content_for_header }}
</head>
<body class="template-{{ request.page_type }}">
  <div id="scroll-progress" aria-hidden="true"></div>

  {% section 'announcement-bar' %}
  {% section 'header' %}

  <main id="top" data-main>
    {{ content_for_layout }}
    {% section 'footer' %}
    <div class="tabbar-spacer" aria-hidden="true"></div>
  </main>

  {% section 'tab-bar' %}

  {% render 'menu-drawer' %}
  {% render 'search-sheet' %}
  {% render 'cart-drawer' %}
  <div class="toast" id="toast" aria-live="polite"></div>

  <script>window.routes = { cart_add: '{{ routes.cart_url }}/add.js', cart: '{{ routes.cart_url }}.js', cart_change: '{{ routes.cart_url }}/change.js', search: '{{ routes.search_url }}' };</script>
  <script src="{{ 'app.js' | asset_url }}" defer></script>
</body>
</html>
