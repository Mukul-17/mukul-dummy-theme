<div class="sheet-root sheet-root--top" id="search-sheet" hidden>
  <div class="sheet__backdrop" data-close></div>
  <div class="search" role="dialog" aria-modal="true" aria-label="Search">
    <form class="search__bar" action="{{ routes.search_url }}" method="get" role="search">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
      <input type="search" id="search-input" name="q" placeholder="Search tees, collections…" autocomplete="off" />
      <button type="button" class="icon-close" data-close aria-label="Close search">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </form>
    <div class="search__suggest">
      <span class="search__label">Popular</span>
      <div class="search__chips">
        {%- assign pops = settings.popular_searches | default: 'Oversized, 240 GSM, Coffee, Who Needs Roads' | split: ',' -%}
        {%- for p in pops -%}{%- assign term = p | strip -%}<button class="chip" data-search="{{ term | escape }}">{{ term }}</button>{%- endfor -%}
      </div>
    </div>
    <div class="search__results" id="search-results"></div>
  </div>
</div>
